# ── Sui Network ──
SUI_NETWORK=testnet                          # testnet | mainnet

# ── Contracts (filled after sui move publish) ──
AUTOYIELD_PACKAGE_ID=0x0
VAULT_ID=0x0
AGENT_CAP_ID=0x0
STRATEGY_REGISTRY_ID=0x0

# ── Agent Wallet ──
AGENT_PRIVATE_KEY=                           # Ed25519 hex private key (64 chars)
GAS_SPONSOR_PRIVATE_KEY=                     # Ed25519 hex private key for gas station
DEEPBOOK_MANAGER_ID=0x0
DEEPBOOK_TRADE_CAP_ID=0x0

# ── AI ──
OPENAI_API_KEY=sk-...

# ── MemWal (Walrus Memory) ──
MEMWAL_DELEGATE_KEY=                         # from memory.walrus.xyz playground
MEMWAL_ACCOUNT_ID=                           # from memory.walrus.xyz playground
MEMWAL_SERVER_URL=https://memwal-relayer.walrus.xyz

# ── Database ──
DATABASE_URL=postgresql://postgres:password@localhost:5432/autoyield
REDIS_URL=redis://localhost:6379

# ── Backend ──
PORT=4000
FRONTEND_URL=http://localhost:3000
LOG_LEVEL=info

# ── Agent loop ──
AGENT_INTERVAL_MS=30000                      # 30 seconds
RISK_TIER=moderate                           # conservative | moderate | aggressive
MAX_DRAWDOWN_BPS=2000                        # 20% max drawdown

# ── Frontend (NEXT_PUBLIC_ prefix = exposed to browser) ──
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_SUI_NETWORK=testnet
NEXT_PUBLIC_VAULT_ID=0x0
NEXT_PUBLIC_GOOGLE_CLIENT_ID=               # from Google Cloud Console
